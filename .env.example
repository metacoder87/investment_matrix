# PostgreSQL / TimescaleDB
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=cryptoinsight
DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/cryptoinsight

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security
ENVIRONMENT=local
# Leave blank for local/dev fallback behavior. Set real values in production.
SECRET_KEY=
ENCRYPTION_KEY=
ADMIN_KEY=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Streaming defaults
PRIMARY_EXCHANGE=kraken
CORE_UNIVERSE=BTC-USD,ETH-USD,SOL-USD
TRACK_TOP_N_COINS=50
STREAM_EXCHANGE=KRAKEN
# Optional: stream from multiple exchanges (comma-separated); overrides STREAM_EXCHANGE when set.
STREAM_EXCHANGES=KRAKEN
# Price source preference when exchange=auto (comma-separated).
PRICE_EXCHANGE_PRIORITY=kraken,coinbase,binance
MARKET_UNIVERSE_TARGET=750
MARKET_DEFAULT_PAGE_SIZE=500
KRAKEN_BACKFILL_BATCH_SIZE=50
KRAKEN_BACKFILL_MAX_ACTIVE=8
KRAKEN_STREAM_TOP_N=100

# Kraken keys are namespaced and optional for paper-only mode. They are not used
# for real order placement in this phase.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Local AI crew runtime. Disabled by default so Docker/local startup does not
# require Ollama or a local model.
CREW_ENABLED=false
CREW_LLM_PROVIDER=ollama
CREW_LLM_BASE_URL=http://host.docker.internal:11434
CREW_LLM_MODEL=llama3.1:8b
CREW_MAX_SYMBOLS_PER_RUN=10
CREW_LLM_TIMEOUT_SECONDS=600
CREW_RESEARCH_ENABLED=false
CREW_TRIGGER_MONITOR_ENABLED=false
CREW_RESEARCH_INTERVAL_SECONDS=1800
CREW_TRIGGER_POLL_SECONDS=5
CREW_BANKROLL_RESET_DRAWDOWN_PCT=0.95
CREW_DEFAULT_STARTING_BANKROLL=10000

# To enable the autonomous paper bot locally after Ollama is running:
# CREW_ENABLED=true
# CREW_RESEARCH_ENABLED=true
# CREW_TRIGGER_MONITOR_ENABLED=true

# Optional plugin keys (leave blank for zero-cost core)
NEWS_API_KEY=
COINMARKETCAP_API_KEY=
FINANCIALMODELINGPREP_API_KEY=
NEWSDATAIO_API_KEY=
COINPAPRIKA_API_KEY=
STOCKGEIST_API_KEY=
SANTIMENT_API_KEY=
LUNARCRUSH_API_KEY=
CRYPTOCOMPARE_API_KEY=

